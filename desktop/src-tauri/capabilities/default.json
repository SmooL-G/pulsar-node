{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:tray:default",
    "core:app:default",
    "core:path:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "shell:allow-open",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
